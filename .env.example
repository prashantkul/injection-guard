# injection-guard environment variables
# Copy this file to .env and fill in your values

# Anthropic (for AnthropicClassifier)
ANTHROPIC_API_KEY=

# OpenAI (for OpenAIClassifier)
OPENAI_API_KEY=

# Google Cloud / Vertex AI (for GeminiClassifier)
GCP_PROJECT_ID=
GCP_REGION=us-central1

# Local LLM (for LocalLLMClassifier — Ollama, vLLM, etc.)
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=llama3.2
